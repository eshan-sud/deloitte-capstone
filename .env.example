# Root Docker Compose configuration
# (Copy to .env)

MYSQL_ROOT_PASSWORD="your-password"
MYSQL_DATABASE="event_management"
MYSQL_HOST_PORT="3307"

# In Docker, avoid dev profile because application-dev uses in-memory H2
SPRING_PROFILES_ACTIVE="prod"
SPRING_DATASOURCE_URL="jdbc:mysql://mysql:3306/event_management?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC"
SPRING_DATASOURCE_USERNAME="root"
SPRING_DATASOURCE_PASSWORD="your-password"
SPRING_JPA_HIBERNATE_DIALECT="org.hibernate.dialect.MySQLDialect"
JWT_SECRET="dev-jwt-secret-change-me-32chars-minimum"

ASPNETCORE_ENVIRONMENT="Development"
ASPNETCORE_URLS="http://+:8080"
ASPNET_CONNECTION_STRING="Server=mysql;Port=3306;Database=event_management;Uid=root;Pwd=your-password;"
CORS_ALLOWED_ORIGIN_0="http://localhost:5173"
CORS_ALLOWED_ORIGIN_1="http://localhost:3000"
REPORTING_ADMIN_API_KEY="dev-reporting-admin-key-12345"

NODE_ENV="development"
NODE_PORT="4000"
NODE_CLIENT_ORIGINS="http://localhost:5173,http://localhost:3000"

NODE_DB_URI="mongodb://mongo:27017/event_notifications"
NODE_MYSQL_HOST="mysql"
NODE_MYSQL_USER="root"
NODE_MYSQL_PASSWORD="your-password"
NODE_MYSQL_DATABASE="event_management"

# Optional email settings for live booking/reminder emails
NODE_EMAIL_SERVICE="gmail"
NODE_EMAIL_HOST="smtp.gmail.com"
NODE_EMAIL_PORT="587"
NODE_EMAIL_USER=""
NODE_EMAIL_PASS=""
NODE_EMAIL_PASSWORD=""
NODE_EMAIL_FROM=""

VITE_SPRING_API_URL="http://localhost:8080/api"
VITE_ASPNET_API_URL="http://localhost:5107/api"
VITE_NODE_API_URL="http://localhost:4000/api"
VITE_REPORTS_ADMIN_KEY="dev-reporting-admin-key-12345"