# ============================================================================
# NODE.JS NOTIFICATION SERVICE - Backend/node-backend/
# ============================================================================
# (Copy to .env)

# MongoDB Configuration
DB_URI="your_mongodb_connection_string"

# Server Configuration
PORT="4000"
NODE_ENV="development"

# CORS Configuration (comma-separated, no spaces)
CLIENT_ORIGINS="http://localhost:5173,http://localhost:3000"

# Email Configuration (optional - for notification sending)
# Replace EMAIL_USER and EMAIL_PASSWORD with a real sender mailbox and app password/token.
# For Gmail, generate an App Password and paste it into EMAIL_PASSWORD.
EMAIL_SERVICE="gmail"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# MySQL Configuration (for querying user/organizer emails from the shared Spring database)
MYSQL_HOST="localhost"
MYSQL_USER="root"
MYSQL_PASSWORD="your-mysql-password"
MYSQL_DATABASE="event_management"

# Node server will start on http://localhost:4000
# API endpoints: http://localhost:4000/api/v1/notifications, /api/v1/notifications/send, /api/v1/notifications/logs