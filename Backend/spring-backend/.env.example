# ============================================================================
# SPRING BOOT - Backend/spring-backend/
# ============================================================================
# (Copy to .env)
# MySQL Database Configuration
SPRING_DATASOURCE_URL="jdbc:mysql://localhost:3306/event_management?createDatabaseIfNotExist=true&serverTimezone=UTC"
SPRING_DATASOURCE_DRIVER_CLASS_NAME="com.mysql.cj.jdbc.Driver"
SPRING_DATASOURCE_USERNAME="root"
SPRING_DATASOURCE_PASSWORD="your-password"

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DIALECT="org.hibernate.dialect.MySQLDialect"
SPRING_JPA_HIBERNATE_DDL_AUTO="update"

# JWT Configuration
JWT_SECRET="your-secret-jwt"
JWT_EXPIRATION="86400000"

# Server Configuration
SERVER_PORT="8080"
SERVER_SERVLET_CONTEXT_PATH="/api"

# Spring Boot will start on http://localhost:8080
# API endpoints: http://localhost:8080/api/auth, /api/events, /api/venues, /api/orders, /api/users, /api/reports