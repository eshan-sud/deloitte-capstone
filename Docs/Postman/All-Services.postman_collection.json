          "}",
          "if (!pm.environment.get('eventStartAt')) {",
          "  pm.environment.set('eventStartAt', '2030-01-15T10:00:00');",
          "}",
          "if (!pm.environment.get('eventEndAt')) {",
          "  pm.environment.set('eventEndAt', '2030-01-15T13:00:00');",
          "}",
          "if (!pm.environment.get('availabilityStartAt')) {",
          "  pm.environment.set('availabilityStartAt', '2030-01-15T10:00:00Z');",
          "}",
          "if (!pm.environment.get('availabilityEndAt')) {",
          "  pm.environment.set('availabilityEndAt', '2030-01-15T13:00:00Z');",
          "}",
          "if (!pm.environment.get('reportFrom')) {",
          "  pm.environment.set('reportFrom', '2024-01-01T00:00:00Z');",
          "}",
          "if (!pm.environment.get('reportTo')) {",
          "  pm.environment.set('reportTo', '2031-01-01T00:00:00Z');",
          "}",
          "if (!pm.environment.get('targetUserId') && pm.environment.get('newUserId')) {",
