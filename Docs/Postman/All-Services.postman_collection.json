    {
      "name": "02 - Spring Auth and Users",
      "item": [
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"user+{{$timestamp}}@eventnest.io\",\n  \"password\": \"{{newUserPassword}}\"\n}"
            },
            "url": "{{springBaseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('Register returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "try {",
                  "  const payload = JSON.parse(pm.request.body.raw);",
                  "  if (payload.email) { pm.environment.set('newUserEmail', payload.email); }",
                  "} catch (e) {}",
                  "if (json && json.data && json.data.user && json.data.user.id) {",
                  "  pm.environment.set('newUserId', String(json.data.user.id));",
                  "  pm.environment.set('targetUserId', String(json.data.user.id));",
                  "}",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('newUserToken', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
